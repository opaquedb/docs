{
  "name": "OpaqueDB Docs",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "remoteUser": "root",
  "postCreateCommand": "make install",
  // Publish 8000 as a raw Docker TCP port instead of VS Code's HTTP
  // forwarding proxy. The proxy truncates the mkdocs dev server's HTTP/1.0
  // responses for CLI clients like curl (curl error 18); a Docker publish
  // passes the bytes through untouched. Requires `mkdocs serve -a 0.0.0.0`.
  "appPort": [8000],
  "portsAttributes": {
    "8000": {
      "label": "MkDocs preview",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "yzhang.markdown-all-in-one",
        "DavidAnson.vscode-markdownlint",
        "redhat.vscode-yaml"
      ]
    }
  }
}
